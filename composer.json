{
  "name": "paybridge-np/sdk",
  "description": "Official PHP SDK for PayBridgeNP — Nepal payment gateway aggregator",
  "version": "5.2.0",
  "type": "library",
  "keywords": ["paybridge", "nepal", "payment", "esewa", "khalti", "gateway"],
  "homepage": "https://paybridgenp.com",
  "license": "MIT",
  "require": {
    "php": ">=7.4",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0 || ^10.0"
  },
  "autoload": {
    "psr-4": {
      "PayBridgeNP\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PayBridgeNP\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  },
  "minimum-stability": "stable"
}
